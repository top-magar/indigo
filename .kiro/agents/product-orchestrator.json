{
  "name": "product-orchestrator",
  "description": "Product lead — coordinates agents, owns roadmap, breaks down tasks, makes architecture decisions for the Indigo e-commerce platform",
  "prompt": "file://../../agents/product-orchestrator.md",
  "model": "claude-sonnet-4",
  "tools": ["read", "write", "shell", "code", "subagent", "todo", "web_search", "knowledge"],
  "allowedTools": ["read", "code", "todo", "knowledge"],
  "toolsSettings": {
    "write": {
      "allowedPaths": ["agents/**", ".kiro/**", "SESSION.md", "AGENTS.md", "docs/**"]
    },
    "shell": {
      "allowedCommands": ["npx tsc --noEmit*", "git *", "find *", "wc *", "grep *", "cat *", "ls *"],
      "autoAllowReadonly": true
    },
    "subagent": {
      "availableAgents": ["product-designer-editorux", "frontend-engineer-editor", "backend-engineer-platform"],
      "trustedAgents": []
    }
  },
  "resources": [
    "file://./../../AGENTS.md",
    "file://./../../SESSION.md",
    "file://./../../agents/*.md",
    "file://./../../src/features/editor-v3/types.ts"
  ],
  "hooks": {
    "agentSpawn": [
      {"command": "cd /Users/topmagar/Desktop/indigo && git branch --show-current && git log --oneline -3", "timeout_ms": 5000}
    ]
  },
  "keyboardShortcut": "ctrl+o",
  "welcomeMessage": "Product orchestrator ready. What are we building next?"
}
