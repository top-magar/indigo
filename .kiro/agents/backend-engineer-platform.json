  },
  "resources": [
    "file://./../../agents/backend-engineer-platform.md",
    "file://./../../src/db/schema/index.ts",
    "file://./../../src/db/schema/editor-projects.ts",
    "file://./../../src/db/schema/editor-project-versions.ts",
